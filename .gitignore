/scripts/delete-candidates.json
/scripts/reclassify-candidates.json
/scripts/reclassify-candidates-strict.json
/scripts/c-pruned-delete-candidates.json

# Operation Cover Zero — local reversal logs + candidate dumps, not source
/scripts/.cover-zero-candidates-auto.txt
/scripts/.cover-zero-cleanup-log-*.json
/scripts/verify-tier1.ts

