/scripts/.cover-placeholder-ids.json
/scripts/.cover-placeholder-null-log-*.json
/scripts/.cover-retailer-recovery-log-*.json
/scripts/.cover-remaining-recovery-log-*.json
/scripts/.cover-priority-recovery-log-*.json
/scripts/cover-debug.ts
/scripts/cover-r2-scan.ts
/scripts/cover-gap-comics.csv
/scripts/under-ninja-v6.ts
